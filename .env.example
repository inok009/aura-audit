# Ollama settings
AURA_OLLAMA_URL=http://localhost:11434
AURA_OLLAMA_MODEL=qwen2.5:1.5b
AURA_OLLAMA_CONCURRENCY=4
AURA_OLLAMA_TIMEOUT=120

# AWS defaults (can be overridden by --profile / --region flags)
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# Output defaults
AURA_OUTPUT_FORMAT=array
AURA_MIN_SEVERITY=LOW